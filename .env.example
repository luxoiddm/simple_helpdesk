# JWT_SECRET: Secret key for signing authentication tokens
JWT_SECRET="viking_secret_key_change_me"

# API_KEY: Secret key for external API access
API_KEY="viking_api_key_for_external_services"

# Server Port
PORT=3030

# Default Admin Credentials (Used only on first initialization)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Email Configuration (IMAP/SMTP)
EMAIL_SUPPORT_ADDR="mail@domain.com"
EMAIL_IMAP_HOST="imap.domain.com"
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER="mail@domain.com"
EMAIL_IMAP_PASS="pass"
EMAIL_IMAP_SECURE=true

EMAIL_SMTP_HOST="smtp.domain.com"
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER="mail@domain.com"
EMAIL_SMTP_PASS="pass"
EMAIL_SMTP_SECURE=true
