# JWT_SECRET: Secret key for signing authentication tokens
JWT_SECRET="your_jwt_secret_key_here"

# API_KEY: Secret key for external API access
API_KEY="your_api_key_here"

# Name site desk
SITE_NAME="SITE_NAME"
# Server Port
PORT=3000

# Database Path
DB_PATH="./database.db"

# Site Name
SITE_NAME="SupportDesk"

# Default Admin Credentials (Used only on first initialization)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Email Configuration (IMAP/SMTP)
EMAIL_SUPPORT_ADDR="support@example.com"
EMAIL_IMAP_HOST="imap.example.com"
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER="support@example.com"
EMAIL_IMAP_PASS="your_password_here"
EMAIL_IMAP_SECURE=true

EMAIL_SMTP_HOST="smtp.example.com"
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER="support@example.com"
EMAIL_SMTP_PASS="your_password_here"
EMAIL_SMTP_SECURE=true
